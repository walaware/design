{
  "name": "@walaware/design",
  "version": "0.9.0",
  "description": "Shared design system for the walaware family of life apps — tokens, the wala wordmark, and Svelte 5 components in the warm Campfire house style.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "author": "walaware",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walaware/design.git"
  },
  "keywords": [
    "walaware",
    "design-system",
    "svelte",
    "tailwind",
    "campfire"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "svelte-kit sync && svelte-package",
    "preversion": "pnpm run check && pnpm run package",
    "postversion": "git push --follow-tags"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "publint": "^0.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
